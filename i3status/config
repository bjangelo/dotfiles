general {
	colors = true
	interval = 5
	color_good = "#6ebaf8"
	color_degraded = "#efdfac"
	color_bad = "#f7786d"
}

order += "volume master"
order += "load"
order += "memory"
order += "disk /"
order += "run_watch VPN"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery 0"
order += "tztime local"

